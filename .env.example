# =============================================================================
# gif — Environment Configuration
# Copy this file to .env and fill in values before running docker compose up.
#
#   cp .env.example .env
#
# Never commit .env — it is gitignored.
# =============================================================================

# PostgreSQL superuser password (Docker-managed postgres user)
POSTGRES_PASSWORD=changeme

# gif_admin: schema owner and migration user. Not used at runtime by the MCP server.
GIF_ADMIN_PASSWORD=changeme

# gif_app: enforcement engine application user. Used by the MCP server at runtime.
# Also used by integration tests when connecting as gif_app.
GIF_APP_PASSWORD=changeme

# Database name (default: gif)
PGDATABASE=gif

# MCP server port (default: 3100)
PORT=3100

# HMAC secret for identity token signing (Sprint 5 compliance hardening).
# Required for persona_create tool and identity binding tests.
# Generate a strong value: openssl rand -hex 32
IDENTITY_HMAC_SECRET=changeme-use-openssl-rand-hex-32
