# Node.js build output
# dist/ is tracked — adopters consume gif-enforcement as a git dependency
# (git+ssh://...#v<tag>) and import from dist/ per package.json exports.
# Rebuild (npm run build) and commit before tagging a release.
mcp-server/node_modules/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store

# Claude Code — ignore all local/runtime data by default; allowlist only the
# assets intentionally shipped to contributors. Allowlist on purpose: a new
# local artifact (logs, caches, state) defaults to ignored, so nothing leaks
# into the public repo by omission — the failure mode that left checkpoints.log
# tracked. To ship a new .claude asset, add an explicit `!` re-include below.
.claude/*
!.claude/skills/
!.claude/agents/

# Internal session state — not for public repository
project-state.md
project-state-archive.md
retrospectives.md
error-patterns.md
